# ===========================================
# Bilibili Login Credentials (Required)
# ===========================================
# How to get:
#   1. Log in to bilibili.com in your browser
#   2. F12 → Application → Cookies → https://www.bilibili.com
#   3. Copy the values below
BILI_SESSDATA=your_sessdata_here
BILI_JCT=your_bili_jct_here
BILI_DEDE_USER_ID=your_dede_user_id_here

# ===========================================
# LLM API Configuration (Required for summarization)
# ===========================================
# OpenAI-compatible API endpoint
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o
# Optional: custom headers as JSON, e.g. {"X-Custom": "value"}
# LLM_EXTRA_HEADERS={}

# ===========================================
# Output Configuration (Optional)
# ===========================================
# Directory to save generated notes (default: ./output)
OUTPUT_DIR=./output
# Note language (default: zh)
NOTE_LANGUAGE=zh
