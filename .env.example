# ===========================================
# Bilibili Credentials (Optional)
# ===========================================
# NOT required for subtitle fetching — Bilibili's subtitle API is public.
# Only needed for Whisper fallback (audio download) on restricted videos.
# Leave empty if you don't need Whisper fallback.
BILI_SESSDATA=
BILI_JCT=
BILI_DEDE_USER_ID=

# ===========================================
# LLM API Configuration (Required for summarization)
# ===========================================
# OpenAI-compatible API endpoint.
# Works with: OpenAI, Proma Cloud, DeepSeek, Ollama, etc.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o
# Optional: custom headers as JSON, e.g. {"X-Custom": "value"}
# LLM_EXTRA_HEADERS={}

# ===========================================
# Output Configuration (Optional)
# ===========================================
# Directory to save generated notes (default: ./output)
OUTPUT_DIR=./output
# Note language (default: zh)
NOTE_LANGUAGE=zh
